# ─── Application ───────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ─── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=crypto_ops
POSTGRES_USER=crypto_ops_user
POSTGRES_PASSWORD=securepassword123
DATABASE_URL=postgresql+asyncpg://crypto_ops_user:securepassword123@localhost:5432/crypto_ops
DATABASE_URL_SYNC=postgresql://crypto_ops_user:securepassword123@localhost:5432/crypto_ops

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── AI / LLM ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
AI_MODEL=gpt-4o
AI_MAX_TOKENS=1024
AI_MAX_RETRIES=3
AI_TIMEOUT_SECONDS=30

# ─── Fraud Detection ────────────────────────────────────────────
FRAUD_HIGH_RISK_THRESHOLD=0.7
FRAUD_MEDIUM_RISK_THRESHOLD=0.4
FRAUD_FLAG_WINDOW_HOURS=24
FRAUD_MAX_COMPLAINTS_PER_WALLET=3
FRAUD_MAX_FAILED_TX_PER_WALLET=5

# ─── Routing ────────────────────────────────────────────────────
HIGH_VALUE_TX_THRESHOLD_USD=10000
